# Supabase browser configuration
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Local-only archive and rubric import scripts
# Never prefix this key with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Server-only ChatGPT narrative generation
# Add these to Vercel, but never prefix them with NEXT_PUBLIC_.
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-5-mini

# Server-only workflow automation and scheduled notifications
# Add these to Vercel Production. Never prefix them with NEXT_PUBLIC_.
CRON_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
# SMTP email delivery (Gmail / Google Workspace app password supported)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=portal@your-domain.org
SMTP_PASSWORD=YOUR_16_CHARACTER_APP_PASSWORD
SMTP_FROM_NAME=GHSMTA Portal
SMTP_FROM_EMAIL=portal@your-domain.org
SMTP_REPLY_TO=optional-reply-address@your-domain.org

# Temporary authentication switch.
# Set to true and redeploy when SMS phone verification is ready.
PHONE_VERIFICATION_ENABLED=false

# Public staff-registration switch.
STAFF_SIGNUP_ENABLED=true
# Server-only code shared directly with approved GHSMTA staff.
STAFF_SIGNUP_ACCESS_CODE=replace-with-a-long-random-code
